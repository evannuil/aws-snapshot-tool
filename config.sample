config = {

    # AWS credentials for the IAM user.
    # Leave empty ('') to use the standard boto3 credential chain instead:
    # environment variables, ~/.aws/credentials, or an IAM instance role.
    'aws_access_key': '',
    'aws_secret_key': '',

    # EC2 region your volumes live in
    'ec2_region_name': 'eu-west-1',

    # Tag of the EBS volumes you want to take snapshots of
    'tag_name': 'MakeSnapshot',
    'tag_value': 'True',

    # Number of snapshots to keep per period (the older ones are going to be
    # deleted, since they cost money).
    'keep_day': 5,
    'keep_week': 5,
    'keep_month': 11,

    # Path to the log for this script
    'log_file': '/var/log/makesnapshots.log',

    # ARN of the SNS topic for run reports (optional)
    #'arn': 'arn:aws:sns:eu-west-1:123456789012:snapshot-reports',

    # Proxy config (optional)
    #'proxyHost': '10.100.x.y',
    #'proxyPort': '8080',
}
